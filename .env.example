# Copy to .env before running docker compose:  cp .env.example .env
# Do not commit .env — it contains secrets.

# PostgreSQL (docker-compose `postgres` service)
POSTGRES_PASSWORD=changeme_local_dev_only
POSTGRES_DB=nakama

# Hostname/IP Nakama uses to reach Postgres on the Compose network.
# Use the service name `postgres` unless your setup requires a fixed IP (e.g. 172.20.0.2).
POSTGRES_HOST=postgres
